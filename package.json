{
  "name": "ownyourmind",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check",
    "deploy": "npm run build && npx wrangler pages deploy dist --project-name ownyourmind --commit-dirty=true",
    "refresh:github": "tsx scripts/refresh-github-metrics.ts",
    "check:staleness": "tsx scripts/flag-stale-records.ts"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@pagefind/default-ui": "^1.4.0",
    "astro": "^5.17.1",
    "react": "^19.2.4",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@tailwindcss/vite": "^4.1.18",
    "pagefind": "^1.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.66.0"
  }
}
