---
interface Step {
  label: string;
  sublabel?: string;
  icon?: string; // emoji or short text
}

interface Props {
  title?: string;
  steps: Step[];
  direction?: 'horizontal' | 'vertical';
}

const { title, steps, direction = 'horizontal' } = Astro.props;

const isHorizontal = direction === 'horizontal';
---

<div class="chart-container my-6" aria-label={title || 'Flow diagram'}>
  {title && (
    <h3 class="text-sm font-semibold text-[var(--color-text-primary)] uppercase tracking-wider mb-4">{title}</h3>
  )}

  <div class={`flex ${isHorizontal ? 'flex-col sm:flex-row items-stretch' : 'flex-col'} gap-0`}>
    {steps.map((step, i) => (
      <>
        {/* Step box */}
        <div class="flex-1 card-elevated p-3 sm:p-4 text-center min-w-0">
          {step.icon && (
            <span class="text-2xl block mb-1">{step.icon}</span>
          )}
          <span class="text-sm font-semibold text-[var(--color-text-primary)] block leading-tight">
            {step.label}
          </span>
          {step.sublabel && (
            <span class="text-xs text-[var(--color-text-tertiary)] block mt-1 leading-tight">
              {step.sublabel}
            </span>
          )}
        </div>

        {/* Arrow */}
        {i < steps.length - 1 && (
          <div class={`flex items-center justify-center ${isHorizontal ? 'py-1 sm:py-0 sm:px-1' : 'py-1'}`}>
            {isHorizontal ? (
              <>
                <svg class="hidden sm:block w-6 h-6 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
                <svg class="sm:hidden w-6 h-6 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 12l-7 7-7-7" />
                </svg>
              </>
            ) : (
              <svg class="w-6 h-6 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 12l-7 7-7-7" />
              </svg>
            )}
          </div>
        )}
      </>
    ))}
  </div>
</div>
