---
import { getOnchainMetrics, getProjectMetrics } from '../data/onchain-metrics';

interface Props {
  slug: string;
}

const { slug } = Astro.props;

const onchain = getOnchainMetrics();
const data = getProjectMetrics(slug);

let metrics: { label: string; value: string; detail?: string }[] = [];
let dataDate: string | null = onchain?.date ?? null;

function fmtSupply(n: number): string {
  if (n >= 1e9) return `${(n / 1e9).toFixed(1)}B`;
  if (n >= 1e6) return `${(n / 1e6).toFixed(1)}M`;
  if (n >= 1e3) return `${(n / 1e3).toFixed(0)}K`;
  return n.toLocaleString('en-US');
}

if (data) {
  // Token supply (handles single-chain and multi-chain)
  const supply = data.token_supply ?? data.token_supply_arbitrum ?? 0;
  if (supply > 0) {
    const supplyLabel = data.token_supply_arbitrum ? 'Supply (Arbitrum)' : 'Token Supply';
    metrics.push({ label: supplyLabel, value: fmtSupply(supply), detail: data.chain });
  }

  // Secondary chain supply (e.g. Morpheus on Ethereum)
  if (data.token_supply_ethereum && data.token_supply_ethereum > 0) {
    metrics.push({ label: 'Supply (Ethereum)', value: fmtSupply(data.token_supply_ethereum) });
  }

  // Staking data (Venice)
  if (data.staked && data.staked > 0) {
    metrics.push({
      label: 'Staked',
      value: fmtSupply(data.staked),
      detail: data.staking_ratio ? `${data.staking_ratio}% of supply` : undefined,
    });
  }

  // DIEM supply (Venice)
  if (data.diem_supply && data.diem_supply > 0) {
    metrics.push({
      label: 'DIEM Supply',
      value: data.diem_supply.toLocaleString('en-US', { maximumFractionDigits: 0 }),
    });
  }
}
---

{metrics.length > 0 && (
  <div class="onchain-metrics">
    <div class="onchain-header">
      <span class="onchain-label">On-chain data</span>
      {dataDate && <span class="onchain-date">{dataDate}</span>}
    </div>
    <div class={`onchain-grid onchain-cols-${Math.min(metrics.length, 3)}`}>
      {metrics.map((m) => (
        <div class="onchain-card">
          <div class="onchain-value">{m.value}</div>
          <div class="onchain-card-label">{m.label}</div>
          {m.detail && <div class="onchain-detail">{m.detail}</div>}
        </div>
      ))}
    </div>
  </div>
)}

<style>
  .onchain-metrics {
    background: rgba(13, 148, 136, 0.06);
    border: 1px solid rgba(13, 148, 136, 0.2);
    border-radius: 0.75rem;
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
  }

  .onchain-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .onchain-label {
    color: var(--color-accent, #0D9488);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .onchain-date {
    color: var(--color-text-tertiary, #6B7280);
    font-size: 0.75rem;
  }

  .onchain-grid {
    display: grid;
    gap: 1rem;
  }

  .onchain-cols-1 { grid-template-columns: 1fr; }
  .onchain-cols-2 { grid-template-columns: repeat(2, 1fr); }
  .onchain-cols-3 { grid-template-columns: repeat(3, 1fr); }

  @media (max-width: 640px) {
    .onchain-grid {
      grid-template-columns: 1fr !important;
    }
  }

  .onchain-card {
    text-align: center;
  }

  .onchain-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary, #F3F4F6);
  }

  .onchain-card-label {
    font-size: 0.8rem;
    color: var(--color-text-secondary, #9CA3AF);
    margin-top: 0.15rem;
  }

  .onchain-detail {
    font-size: 0.7rem;
    color: var(--color-text-tertiary, #6B7280);
    margin-top: 0.15rem;
  }
</style>
