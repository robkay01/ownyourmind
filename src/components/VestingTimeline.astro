---
interface TimelineEvent {
  date: string;
  label: string;
  percentage?: number;
  completed?: boolean;
}

interface Props {
  events: TimelineEvent[];
  title?: string;
}

const { events, title = 'Vesting timeline' } = Astro.props;

// Only render if 2+ events
if (events.length < 2) return;

// Sort: completed first, then by date string
const sorted = [...events].sort((a, b) => {
  if (a.completed && !b.completed) return -1;
  if (!a.completed && b.completed) return 1;
  return a.date.localeCompare(b.date);
});
---

<div class="chart-container-compact" aria-label={title}>
  <h3 class="text-sm font-semibold text-[var(--color-text-primary)] uppercase tracking-wider mb-3">{title}</h3>

  <div class="flex flex-col gap-0">
    {sorted.map((evt, i) => {
      const isCompleted = evt.completed ?? false;
      const isLast = i === sorted.length - 1;

      return (
        <div class="flex gap-3">
          {/* Vertical track */}
          <div class="flex flex-col items-center shrink-0">
            <div
              class="w-3 h-3 rounded-full border-2 shrink-0"
              style={`
                border-color: var(--color-accent);
                background-color: ${isCompleted ? 'var(--color-accent)' : 'var(--color-bg-primary)'};
              `}
            />
            {!isLast && (
              <div class="w-0.5 flex-1 min-h-6" style="background-color: var(--color-border);" />
            )}
          </div>

          {/* Content */}
          <div class={`pb-4 ${isLast ? '' : ''}`}>
            <div class="flex items-center gap-2 flex-wrap">
              <span class="text-xs font-mono text-[var(--color-text-tertiary)]">{evt.date}</span>
              {evt.percentage != null && (
                <span class="text-xs font-mono font-semibold text-[var(--color-accent)]">{evt.percentage}%</span>
              )}
            </div>
            <p class="text-sm text-[var(--color-text-secondary)] mt-0.5">{evt.label}</p>
          </div>
        </div>
      );
    })}
  </div>
</div>
