---
interface Event {
  date: string;
  title: string;
  description?: string;
  status?: 'completed' | 'active' | 'upcoming';
}

interface Props {
  title?: string;
  events: Event[];
}

const { title, events } = Astro.props;

const statusColor = (s?: string) =>
  s === 'completed' ? '#10B981' : s === 'active' ? 'var(--color-accent)' : 'var(--color-text-tertiary)';
---

<div class="chart-container my-6" aria-label={title || 'Timeline'}>
  {title && (
    <h3 class="text-sm font-semibold text-[var(--color-text-primary)] uppercase tracking-wider mb-4">{title}</h3>
  )}

  <div class="relative pl-6 border-l-2 border-[var(--color-border)] space-y-6">
    {events.map((event) => (
      <div class="relative">
        {/* Dot */}
        <div
          class="absolute -left-[calc(0.75rem+1.5px)] top-0.5 w-3 h-3 rounded-full border-2 border-[var(--color-bg-primary)]"
          style={`background-color: ${statusColor(event.status)};`}
        />

        {/* Content */}
        <div class="ml-2">
          <span class="text-xs font-mono text-[var(--color-text-tertiary)] block">
            {event.date}
          </span>
          <span class="text-sm font-semibold text-[var(--color-text-primary)] block mt-0.5">
            {event.title}
          </span>
          {event.description && (
            <span class="text-xs text-[var(--color-text-secondary)] block mt-0.5 leading-relaxed">
              {event.description}
            </span>
          )}
        </div>
      </div>
    ))}
  </div>
</div>
