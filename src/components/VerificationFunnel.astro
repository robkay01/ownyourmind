---
interface FunnelStep {
  label: string;
  value: string;
  source: string;
  width: number; // percentage width 0-100
}

interface Props {
  title?: string;
  steps: FunnelStep[];
}

const { title, steps } = Astro.props;
---

<div class="chart-container" aria-label={title || 'Verification funnel'}>
  {title && (
    <h3 class="text-sm font-semibold text-[var(--color-text-primary)] uppercase tracking-wider mb-4">{title}</h3>
  )}

  <div class="space-y-3">
    {steps.map((step, i) => (
      <div class="space-y-1">
        <div class="flex items-baseline justify-between gap-2">
          <span class="text-xs text-[var(--color-text-tertiary)]">{step.source}</span>
          <span class="text-xs text-[var(--color-text-tertiary)]">{step.label}</span>
        </div>
        <div class="relative h-10 rounded-md overflow-hidden bg-[var(--color-bg-primary)]">
          <div
            class="h-full rounded-md flex items-center justify-end pr-3 transition-all"
            style={`width: ${step.width}%; background-color: ${i === steps.length - 1 ? 'var(--color-accent)' : 'var(--color-bg-tertiary)'};`}
          >
            <span class="font-[var(--font-heading)] text-lg font-bold text-[var(--color-text-primary)]">
              {step.value}
            </span>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
