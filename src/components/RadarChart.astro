---
import type { FreedomScoreBreakdown } from '../data/project-research';

interface Props {
  breakdown: FreedomScoreBreakdown;
  size?: number;
}

const { breakdown, size = 400 } = Astro.props;

const dimensions = [
  { key: 'infrastructure_decentralisation', label: 'Infrastructure' },
  { key: 'governance_decentralisation', label: 'Governance' },
  { key: 'token_distribution_fairness', label: 'Token Distribution' },
  { key: 'censorship_resistance', label: 'Censorship Resistance' },
  { key: 'data_sovereignty', label: 'Data Sovereignty' },
  { key: 'open_source_transparency', label: 'Open Source' },
] as const;

const cx = size / 2;
const cy = size / 2;
const radius = size * 0.28;
const labelRadius = radius + 32;

function polarToXY(angle: number, r: number): [number, number] {
  return [cx + r * Math.cos(angle), cy + r * Math.sin(angle)];
}

// 6 axes at 60-degree intervals, starting from top (-PI/2)
const angles = dimensions.map((_, i) => -Math.PI / 2 + (2 * Math.PI * i) / 6);

// Normalise scores: score/max per dimension
const normalisedValues = dimensions.map((dim) => {
  const d = breakdown[dim.key as keyof FreedomScoreBreakdown];
  if (!d || d.score == null || d.max == null || d.max === 0) return 0;
  return d.score / d.max;
});

// Raw scores for display
const rawScores = dimensions.map((dim) => {
  const d = breakdown[dim.key as keyof FreedomScoreBreakdown];
  if (!d || d.score == null) return null;
  return { score: d.score, max: d.max ?? 20 };
});

// Gridlines at 25%, 50%, 75%, 100%
const gridLevels = [0.25, 0.5, 0.75, 1.0];
const gridPaths = gridLevels.map((level) => {
  const points = angles.map((angle) => polarToXY(angle, radius * level));
  return points.map((p) => `${p[0].toFixed(1)},${p[1].toFixed(1)}`).join(' ');
});

// Data polygon
const dataPoints = angles.map((angle, i) => polarToXY(angle, radius * normalisedValues[i]));
const dataPath = dataPoints.map((p) => `${p[0].toFixed(1)},${p[1].toFixed(1)}`).join(' ');

// Axis endpoints
const axisEnds = angles.map((angle) => polarToXY(angle, radius));

// Label positions — pushed further out for readability
const labelPositions = angles.map((angle) => polarToXY(angle, labelRadius));

// Score badge colour
function scoreBadgeColor(score: number, max: number): string {
  const pct = score / max;
  if (pct >= 0.75) return '#10B981';
  if (pct >= 0.5) return '#F59E0B';
  return '#EF4444';
}
---

<div class="chart-container" aria-label="Freedom Score radar chart showing six dimensions">
  <svg
    width="100%"
    viewBox={`0 0 ${size} ${size}`}
    class="mx-auto block"
    style={`max-width: ${size}px;`}
    role="img"
  >
    <title>Freedom Score breakdown across six dimensions</title>

    {/* Gridlines */}
    {gridPaths.map((points, gi) => (
      <polygon
        points={points}
        fill="none"
        stroke="var(--color-border)"
        stroke-width={gi === gridLevels.length - 1 ? '1.5' : '0.75'}
        opacity={gi === gridLevels.length - 1 ? '0.6' : '0.3'}
      />
    ))}

    {/* Axis lines */}
    {axisEnds.map(([ex, ey]) => (
      <line
        x1={cx}
        y1={cy}
        x2={ex.toFixed(1)}
        y2={ey.toFixed(1)}
        stroke="var(--color-border)"
        stroke-width="0.75"
        opacity="0.3"
      />
    ))}

    {/* Data polygon — filled area */}
    <polygon
      points={dataPath}
      fill="rgba(13, 148, 136, 0.15)"
      stroke="var(--color-accent)"
      stroke-width="2.5"
      stroke-linejoin="round"
    />

    {/* Data points */}
    {dataPoints.map(([px, py]) => (
      <circle
        cx={px.toFixed(1)}
        cy={py.toFixed(1)}
        r="4"
        fill="var(--color-accent)"
        stroke="var(--color-bg-secondary)"
        stroke-width="2"
      />
    ))}

    {/* Dimension labels + scores */}
    {labelPositions.map(([lx, ly], i) => {
      const angle = angles[i];
      const isTop = angle < -Math.PI / 4 && angle > -3 * Math.PI / 4;
      const isBottom = angle > Math.PI / 4 && angle < 3 * Math.PI / 4;
      const isLeft = Math.cos(angle) < -0.2;
      const isRight = Math.cos(angle) > 0.2;

      const anchor = isLeft ? 'end' : isRight ? 'start' : 'middle';

      // Nudge labels outward for breathing room
      const nudgeX = isLeft ? -6 : isRight ? 6 : 0;
      const nudgeY = isTop ? -8 : isBottom ? 8 : 0;
      const finalX = lx + nudgeX;
      const finalY = ly + nudgeY;

      const raw = rawScores[i];
      const color = raw ? scoreBadgeColor(raw.score, raw.max) : 'var(--color-text-tertiary)';

      return (
        <g>
          {/* Label text */}
          <text
            x={finalX.toFixed(1)}
            y={finalY.toFixed(1)}
            text-anchor={anchor}
            dominant-baseline="central"
            fill="var(--color-text-primary)"
            font-size="13"
            font-weight="500"
            font-family="var(--font-body)"
          >
            {dimensions[i].label}
          </text>

          {/* Score below label */}
          {raw && (
            <text
              x={finalX.toFixed(1)}
              y={(finalY + 16).toFixed(1)}
              text-anchor={anchor}
              dominant-baseline="central"
              fill={color}
              font-size="13"
              font-weight="700"
              font-family="var(--font-heading)"
            >
              {raw.score}
              <tspan fill="var(--color-text-tertiary)" font-weight="400" font-size="11">/{raw.max}</tspan>
            </text>
          )}
        </g>
      );
    })}
  </svg>
</div>
