---
const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'WHY DeAI', href: '/why-deai/' },
  { label: 'PROJECTS', href: '/projects/', children: [
    { label: 'Compare', href: '/projects/compare/' },
  ]},
  { label: 'TOKENOMICS', href: '/tokenomics/' },
  { label: 'RESOURCES', href: '/resources/' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg-primary)]/95 backdrop-blur-md">
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 no-underline group">
        <span class="font-[var(--font-heading)] text-lg font-bold tracking-tight text-[var(--color-text-primary)]">OWN YOUR MIND</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          item.children ? (
            <div class="relative group">
              <a
                href={item.href}
                class:list={[
                  'px-3 py-2 text-sm font-medium rounded-md transition-colors no-underline',
                  isActive(item.href)
                    ? 'text-[var(--color-accent)] bg-[var(--color-accent)]/10'
                    : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)]',
                ]}
              >
                {item.label}
              </a>
              <div class="absolute left-0 top-full pt-1 hidden group-hover:block z-50">
                <div class="rounded-md border border-[var(--color-border)] bg-[var(--color-bg-secondary)] shadow-lg py-1 min-w-[140px]">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={[
                        'block px-3 py-1.5 text-sm no-underline transition-colors',
                        isActive(child.href)
                          ? 'text-[var(--color-accent)] bg-[var(--color-accent)]/10'
                          : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)]',
                      ]}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class:list={[
                'px-3 py-2 text-sm font-medium rounded-md transition-colors no-underline',
                isActive(item.href)
                  ? 'text-[var(--color-accent)] bg-[var(--color-accent)]/10'
                  : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)]',
              ]}
            >
              {item.label}
            </a>
          )
        ))}
      </div>

      <!-- Search + Mobile Menu -->
      <div class="flex items-center gap-3">
        <!-- Search Button -->
        <button
          class="flex items-center gap-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-3 py-1.5 text-sm text-[var(--color-text-tertiary)] hover:border-[var(--color-border-hover)] hover:text-[var(--color-text-secondary)] transition-colors"
          aria-label="Search"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <span class="hidden sm:inline">Search</span>
          <kbd class="hidden sm:inline-flex h-5 items-center rounded border border-[var(--color-border)] px-1.5 font-[var(--font-mono)] text-[10px] text-[var(--color-text-tertiary)]">Ctrl K</kbd>
        </button>

        <!-- Mobile Menu Toggle -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden flex items-center justify-center w-9 h-9 rounded-md text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-tertiary)] transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-[var(--color-border)] bg-[var(--color-bg-secondary)] max-h-[calc(100vh-4rem)] overflow-y-auto">
    <div class="px-4 py-4 space-y-1">
      {navItems.map((item) => (
        <>
          <a
            href={item.href}
            class:list={[
              'block px-3 py-2 text-sm font-medium rounded-md no-underline',
              isActive(item.href)
                ? 'text-[var(--color-accent)] bg-[var(--color-accent)]/10'
                : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)]',
            ]}
          >
            {item.label}
          </a>
          {item.children?.map((child) => (
            <a
              href={child.href}
              class:list={[
                'block pl-6 px-3 py-1.5 text-sm rounded-md no-underline',
                isActive(child.href)
                  ? 'text-[var(--color-accent)] bg-[var(--color-accent)]/10'
                  : 'text-[var(--color-text-tertiary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)]',
              ]}
            >
              {child.label}
            </a>
          ))}
        </>
      ))}
    </div>
  </div>
</header>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;

    menu.classList.add('hidden');
    btn.setAttribute('aria-expanded', 'false');

    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
    });
  }

  document.addEventListener('astro:page-load', initMobileMenu);
</script>
