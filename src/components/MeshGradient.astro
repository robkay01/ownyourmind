---
interface Props {
  variant?: 'hero' | 'section' | 'subtle';
  colors?: string[];
}

const { variant = 'subtle', colors } = Astro.props;

const presets: Record<string, { layers: string[]; opacity: number }> = {
  hero: {
    layers: [
      'radial-gradient(ellipse at 20% 20%, rgba(13, 148, 136, 0.12) 0%, transparent 55%)',
      'radial-gradient(ellipse at 75% 60%, rgba(99, 102, 241, 0.08) 0%, transparent 50%)',
      'radial-gradient(ellipse at 40% 80%, rgba(6, 182, 212, 0.06) 0%, transparent 45%)',
    ],
    opacity: 1,
  },
  section: {
    layers: [
      'radial-gradient(ellipse at 30% 40%, rgba(13, 148, 136, 0.08) 0%, transparent 50%)',
      'radial-gradient(ellipse at 70% 60%, rgba(99, 102, 241, 0.05) 0%, transparent 45%)',
    ],
    opacity: 1,
  },
  subtle: {
    layers: [
      'radial-gradient(ellipse at 50% 50%, rgba(13, 148, 136, 0.03) 0%, transparent 60%)',
    ],
    opacity: 1,
  },
};

const config = presets[variant];
const backgroundLayers = colors
  ? colors.map((c, i) => `radial-gradient(ellipse at ${20 + i * 30}% ${30 + i * 20}%, ${c} 0%, transparent 50%)`)
  : config.layers;
---

<div
  class="absolute inset-0 pointer-events-none overflow-hidden"
  aria-hidden="true"
>
  {backgroundLayers.map((layer, i) => (
    <div
      class="gradient-layer absolute inset-0"
      style={`
        background: ${layer};
        opacity: ${config.opacity};
        animation: gradient-drift ${20 + i * 8}s ease-in-out ${i * -7}s infinite;
      `}
    />
  ))}
</div>
