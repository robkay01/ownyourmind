---
import Sparkline from './Sparkline.astro';

interface Props {
  value: string;
  label: string;
  change?: number;
  changeLabel?: string;
  sparklineData?: number[];
}

const { value, label, change, changeLabel, sparklineData } = Astro.props;

const changeColor = change != null
  ? change >= 0 ? '#10B981' : '#EF4444'
  : undefined;

const changeText = change != null
  ? `${change >= 0 ? '+' : ''}${change.toFixed(1)}%`
  : undefined;
---

<div class="card-elevated p-4">
  <span class="text-xs text-[var(--color-text-tertiary)] uppercase tracking-wider block mb-1.5">{label}</span>
  <div class="flex items-end justify-between gap-2">
    <span class="font-[var(--font-heading)] text-xl font-bold text-[var(--color-text-primary)] leading-none">{value}</span>
    {sparklineData && sparklineData.length > 1 && (
      <Sparkline data={sparklineData} width={56} height={20} color={changeColor || 'var(--color-accent)'} />
    )}
  </div>
  {changeText && (
    <div class="flex items-center gap-1 mt-1.5">
      <span class="text-xs font-mono" style={`color: ${changeColor};`}>{changeText}</span>
      {changeLabel && <span class="text-xs text-[var(--color-text-tertiary)]">{changeLabel}</span>}
    </div>
  )}
</div>
