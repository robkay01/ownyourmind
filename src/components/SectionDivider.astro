---
interface Props {
  image: string;
  alt?: string;
  height?: 'sm' | 'md' | 'lg';
}

const { image, alt = '', height = 'sm' } = Astro.props;

const heightClasses: Record<string, string> = {
  sm: 'h-24 sm:h-32',
  md: 'h-32 sm:h-48',
  lg: 'h-48 sm:h-64',
};
---

<div class={`relative overflow-hidden ${heightClasses[height]} my-0`}>
  <img
    src={image}
    alt={alt}
    class="w-full h-full object-cover opacity-30"
    loading="lazy"
  />
  <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-bg-primary)] via-transparent to-[var(--color-bg-primary)]"></div>
</div>
