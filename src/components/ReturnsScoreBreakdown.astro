---
/**
 * Returns Score breakdown — mirrors FreedomScoreBreakdown layout.
 * Shows 5 dimension bars with scores, grade badge, evidence dropdowns,
 * auto-generated summary, and methodology link.
 */
interface Props {
  returnsScore: number;          // 1-10 scale from frontmatter
  breakdown?: {
    tokenUtility?: number;        // /20
    valueAccrual?: number;        // /20
    supplyDynamics?: number;      // /20
    revenueSustainability?: number; // /25
    liquidityAccess?: number;     // /15
  };
  evidence?: {
    tokenUtility?: string;
    valueAccrual?: string;
    supplyDynamics?: string;
    revenueSustainability?: string;
    liquidityAccess?: string;
  };
}

const { returnsScore, breakdown, evidence } = Astro.props;

const raw = Math.round(returnsScore * 10);
const grade = raw >= 85 ? 'A' : raw >= 70 ? 'B' : raw >= 55 ? 'C' : raw >= 40 ? 'D' : 'F';

type DimKey = 'tokenUtility' | 'valueAccrual' | 'supplyDynamics' | 'revenueSustainability' | 'liquidityAccess';

const dimensions: { key: DimKey; label: string; score: number | undefined; max: number }[] = breakdown ? [
  { key: 'tokenUtility', label: 'Token utility', score: breakdown.tokenUtility, max: 20 },
  { key: 'valueAccrual', label: 'Value accrual', score: breakdown.valueAccrual, max: 20 },
  { key: 'supplyDynamics', label: 'Supply dynamics', score: breakdown.supplyDynamics, max: 20 },
  { key: 'revenueSustainability', label: 'Revenue sustainability', score: breakdown.revenueSustainability, max: 25 },
  { key: 'liquidityAccess', label: 'Liquidity & access', score: breakdown.liquidityAccess, max: 15 },
] : [];

// Auto-generate summary from breakdown data
function buildSummary(): string | null {
  if (!breakdown || dimensions.every(d => d.score == null)) return null;

  const scored = dimensions
    .filter(d => d.score != null)
    .map(d => ({ ...d, pct: d.score! / d.max }));

  if (scored.length === 0) return null;

  const strongest = scored.reduce((a, b) => b.pct > a.pct ? b : a);
  const weakest = scored.reduce((a, b) => b.pct < a.pct ? b : a);

  const gradeWord = grade === 'A' ? 'excellent' : grade === 'B' ? 'strong' : grade === 'C' ? 'moderate' : grade === 'D' ? 'below average' : 'weak';

  return `Overall returns potential is ${gradeWord} at ${raw}/100. Strongest dimension: ${strongest.label.toLowerCase()} (${strongest.score}/${strongest.max}). Weakest: ${weakest.label.toLowerCase()} (${weakest.score}/${weakest.max}).`;
}

const summary = buildSummary();

function barColor(score: number | undefined, max: number): string {
  if (score == null || max === 0) return '#64748B';
  const pct = score / max;
  if (pct >= 0.75) return '#10B981';
  if (pct >= 0.5) return '#F59E0B';
  return '#EF4444';
}

function gradeColor(g: string): string {
  switch (g) {
    case 'A': return 'freedom-breakdown-grade-a';
    case 'B': return 'freedom-breakdown-grade-b';
    case 'C': return 'freedom-breakdown-grade-c';
    case 'D': return 'freedom-breakdown-grade-d';
    case 'F': return 'freedom-breakdown-grade-f';
    default: return 'badge-dormant';
  }
}
---

<div class="freedom-breakdown-container">
  <!-- Header -->
  <div class="freedom-breakdown-header">
    <span class="freedom-breakdown-label">Returns Score</span>
    <div class="flex items-center gap-2">
      <span class:list={['badge', gradeColor(grade)]}>
        {grade}
      </span>
      <span class="freedom-breakdown-total">{raw}<span class="freedom-breakdown-max">/100</span></span>
      <a href="/resources/returns-score-methodology/" class="text-xs text-[var(--color-text-tertiary)] hover:text-[var(--color-accent)]" title="Returns Score Methodology">?</a>
    </div>
  </div>

  {summary && (
    <p class="freedom-breakdown-summary">{summary}</p>
  )}

  <!-- Sub-score bars -->
  {dimensions.length > 0 && (
    <div class="freedom-breakdown-bars">
      {dimensions.map(dim => {
        if (dim.score == null) return null;
        const pct = dim.max > 0 ? (dim.score / dim.max) * 100 : 0;
        const color = barColor(dim.score, dim.max);
        const dimEvidence = evidence?.[dim.key];

        return (
          <div class="freedom-breakdown-row">
            <div class="freedom-breakdown-row-inner">
              <span class="freedom-breakdown-dim-label">{dim.label}</span>
              <div class="freedom-breakdown-bar-track">
                <div
                  class="freedom-breakdown-bar-fill"
                  style={`width: ${pct}%; background-color: ${color};`}
                />
              </div>
              <span class="freedom-breakdown-dim-score" style={`color: ${color};`}>
                {dim.score}<span class="freedom-breakdown-dim-max">/{dim.max}</span>
              </span>
            </div>
            {dimEvidence && (
              <details class="freedom-breakdown-evidence">
                <summary class="freedom-breakdown-evidence-toggle">
                  Evidence
                  <svg class="freedom-breakdown-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </summary>
                <div class="freedom-breakdown-evidence-text">
                  {dimEvidence}
                </div>
              </details>
            )}
          </div>
        );
      })}
    </div>
  )}
</div>
