---
interface Props {
  website?: string;
  xHandle?: string;
  githubUrl?: string;
  docsUrl?: string;
  whitepaperUrl?: string;
  chain?: string;
  tokenStandard?: string;
  token?: string;
  discordUrl?: string;
  telegramUrl?: string;
  contractAddress?: string;
}

const { website, xHandle, githubUrl, docsUrl, whitepaperUrl, chain, tokenStandard, token, discordUrl, telegramUrl, contractAddress } = Astro.props;

const truncateAddress = (addr: string) =>
  addr.length > 12 ? `${addr.slice(0, 6)}...${addr.slice(-4)}` : addr;

const hasLinks = website || xHandle || githubUrl || docsUrl || whitepaperUrl || discordUrl || telegramUrl;
const hasTokenDetails = chain || tokenStandard;
---

{(hasLinks || hasTokenDetails) && (
  <div class="p-5 rounded-xl bg-[var(--color-bg-secondary)]/60 backdrop-blur-sm border border-[var(--color-border)] mt-4">

    {hasLinks && (
      <div>
        <span class="text-xs uppercase tracking-wider text-[var(--color-text-tertiary)] font-medium block mb-3">Project Links</span>
        <div class="flex flex-wrap gap-2">

          {website && (
            <a href={website} target="_blank" rel="noopener" class="info-pill">
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
              <span>Website</span>
            </a>
          )}

          {xHandle && (
            <a href={`https://x.com/${xHandle}`} target="_blank" rel="noopener" class="info-pill">
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              <span>@{xHandle}</span>
            </a>
          )}

          {githubUrl && (
            <a href={githubUrl} target="_blank" rel="noopener" class="info-pill">
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              <span>GitHub</span>
            </a>
          )}

          {docsUrl && (
            <a href={docsUrl} target="_blank" rel="noopener" class="info-pill">
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
              </svg>
              <span>Docs</span>
            </a>
          )}

          {whitepaperUrl && (
            <a href={whitepaperUrl} target="_blank" rel="noopener" class="info-pill">
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
              <span>Whitepaper</span>
            </a>
          )}

          {discordUrl && (
            <a href={discordUrl} target="_blank" rel="noopener" class="info-pill">
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286z"/>
              </svg>
              <span>Discord</span>
            </a>
          )}

          {telegramUrl && (
            <a href={telegramUrl} target="_blank" rel="noopener" class="info-pill">
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
              </svg>
              <span>Telegram</span>
            </a>
          )}

        </div>
      </div>
    )}

    {hasTokenDetails && (
      <div class:list={[hasLinks && 'mt-4 pt-4 border-t border-[var(--color-border)]']}>
        <span class="text-xs uppercase tracking-wider text-[var(--color-text-tertiary)] font-medium block mb-3">Token Details</span>
        <div class="flex flex-wrap items-center gap-2">

          {token && (
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-[var(--color-accent-muted)] text-[var(--color-accent)] text-sm font-mono font-medium">
              {token}
            </span>
          )}

          {chain && (
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-[var(--color-bg-tertiary)] text-[var(--color-text-secondary)] text-sm border border-[var(--color-border)]">
              <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
              {chain}
            </span>
          )}

          {contractAddress && (
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-[var(--color-bg-tertiary)] text-[var(--color-text-secondary)] text-sm font-mono border border-[var(--color-border)]">
              {truncateAddress(contractAddress)}
              <button
                class="copy-address-btn ml-0.5 p-0.5 rounded hover:bg-[var(--color-bg-primary)] transition-colors"
                data-address={contractAddress}
                title="Copy contract address"
                aria-label="Copy contract address"
              >
                <svg class="w-3.5 h-3.5 copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                </svg>
                <svg class="w-3.5 h-3.5 check-icon hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </button>
            </span>
          )}

        </div>
      </div>
    )}

  </div>
)}

<style>
  .info-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    transition: all 0.15s ease;
    text-decoration: none;
  }
  .info-pill:hover {
    color: var(--color-text-primary);
    border-color: var(--color-accent);
    background: var(--color-accent-muted);
  }
</style>

<script>
  document.querySelectorAll('.copy-address-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const address = (btn as HTMLElement).dataset.address;
      if (!address) return;
      try {
        await navigator.clipboard.writeText(address);
        const copyIcon = btn.querySelector('.copy-icon') as HTMLElement;
        const checkIcon = btn.querySelector('.check-icon') as HTMLElement;
        copyIcon.classList.add('hidden');
        checkIcon.classList.remove('hidden');
        setTimeout(() => {
          copyIcon.classList.remove('hidden');
          checkIcon.classList.add('hidden');
        }, 2000);
      } catch {
        // Fallback: select text if clipboard API unavailable
      }
    });
  });
</script>
