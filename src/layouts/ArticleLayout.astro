---
import ContentLayout from './ContentLayout.astro';
import PodcastPlayer from '../components/PodcastPlayer.astro';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  section: string;
  sectionHref: string;
  heroImage?: string;
  podcastUrl?: string;
}

const { title, description, publishDate, updatedDate, section, sectionHref, heroImage, podcastUrl } = Astro.props;

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const articleLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishDate.toISOString(),
  ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
  ...(heroImage ? { image: new URL(heroImage, Astro.site).href } : {}),
  author: {
    '@type': 'Person',
    name: 'Bobski',
    url: new URL('/about/', Astro.site).href,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Own Your Mind',
    url: Astro.site?.href,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(Astro.url.pathname, Astro.site).href,
  },
});
---

<ContentLayout
  title={title}
  description={description}
  ogImage={heroImage}
  breadcrumbs={[
    { label: section, href: sectionHref },
    { label: title },
  ]}
>
  <script type="application/ld+json" set:html={articleLd} />
  <article class="max-w-3xl">
    {heroImage && (
      <div class="relative -mx-4 sm:-mx-6 mb-8 rounded-xl overflow-hidden">
        <img
          src={heroImage}
          alt=""
          class="w-full h-48 sm:h-64 object-cover"
          loading="eager"
          onerror="this.parentElement.style.display='none'"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-secondary)] via-transparent to-transparent" />
      </div>
    )}
    {podcastUrl && <PodcastPlayer url={podcastUrl} title={title} />}

    <header class="mb-10">
      <div class="flex items-center gap-3 text-sm text-[var(--color-text-tertiary)] mb-4">
        <time datetime={publishDate.toISOString()}>
          {formatDate(publishDate)}
        </time>
        {updatedDate && (
          <span>
            · Updated <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
          </span>
        )}
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold leading-tight mb-4">{title}</h1>
      <p class="text-lg text-[var(--color-text-secondary)] leading-relaxed">{description}</p>
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</ContentLayout>
