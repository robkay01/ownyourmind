---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description?: string;
  breadcrumbs: Crumb[];
  ogImage?: string;
}

const { title, description, breadcrumbs, ogImage } = Astro.props;

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.label,
    ...(crumb.href ? { item: new URL(crumb.href, Astro.site).href } : {}),
  })),
});
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <script type="application/ld+json" set:html={breadcrumbLd} />
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <Breadcrumbs items={breadcrumbs} />
    <slot />
  </div>
</BaseLayout>
