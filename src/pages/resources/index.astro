---
import ContentLayout from '../../layouts/ContentLayout.astro';
import Card from '../../components/Card.astro';
import MeshGradient from '../../components/MeshGradient.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('resources'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<ContentLayout
  title="Resources"
  description="Reference material, directories, and tools for the decentralised AI ecosystem."
  breadcrumbs={[{ label: 'Resources' }]}
>
  <div class="relative -mx-4 sm:-mx-6 lg:-mx-8 mb-10 overflow-hidden rounded-xl">
    <div class="w-full h-48 sm:h-56 bg-[var(--color-bg-secondary)]"></div>
    <MeshGradient variant="hero" />
    <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-primary)] via-[var(--color-bg-primary)]/60 to-transparent"></div>
    <div class="absolute inset-0 flex items-end p-6 sm:p-8">
      <div>
        <h1 class="text-3xl sm:text-4xl font-bold mb-2">Resources</h1>
        <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl">
          Reference material, directories, and tools for the decentralised AI ecosystem.
        </p>
      </div>
    </div>
  </div>

  <div class="grid gap-6">
    {entries.map((entry) => (
      <Card href={`/resources/${entry.id}/`}>
        <h2 class="text-xl font-semibold mb-2">{entry.data.title}</h2>
        <p class="text-[var(--color-text-secondary)]">{entry.data.description}</p>
      </Card>
    ))}
  </div>

  {entries.length === 0 && (
    <p class="text-[var(--color-text-tertiary)] py-12 text-center">Coming soon.</p>
  )}
</ContentLayout>
