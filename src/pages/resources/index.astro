---
import ContentLayout from '../../layouts/ContentLayout.astro';
import Card from '../../components/Card.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('resources'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<ContentLayout
  title="Resources"
  description="Reference material, directories, and tools for the decentralised AI ecosystem."
  breadcrumbs={[{ label: 'Resources' }]}
>
  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold mb-4">Resources</h1>
    <p class="text-lg text-[var(--color-text-secondary)]">
      Reference material, directories, and tools for the decentralised AI ecosystem.
    </p>
  </div>

  <div class="grid gap-6">
    {entries.map((entry) => (
      <Card href={`/resources/${entry.id}/`}>
        <h2 class="text-xl font-semibold mb-2">{entry.data.title}</h2>
        <p class="text-[var(--color-text-secondary)]">{entry.data.description}</p>
      </Card>
    ))}
  </div>

  {entries.length === 0 && (
    <p class="text-[var(--color-text-tertiary)] py-12 text-center">Coming soon.</p>
  )}
</ContentLayout>
