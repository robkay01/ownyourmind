---
import ContentLayout from '../../layouts/ContentLayout.astro';
import Card from '../../components/Card.astro';
import MeshGradient from '../../components/MeshGradient.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('tokenomics'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<ContentLayout
  title="Tokenomics"
  description="How the tokens actually work. What gets burned, what gets diluted, what gets ignored."
  breadcrumbs={[{ label: 'Tokenomics' }]}
>
  <div class="relative -mx-4 sm:-mx-6 lg:-mx-8 mb-10 overflow-hidden rounded-xl">
    <img src="/images/tokenomics-header.webp" alt="" class="w-full h-48 sm:h-56 object-cover opacity-40" loading="eager" />
    <MeshGradient variant="subtle" />
    <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-primary)] via-[var(--color-bg-primary)]/60 to-transparent"></div>
    <div class="absolute inset-0 flex items-end p-6 sm:p-8">
      <div>
        <h1 class="text-3xl sm:text-4xl font-bold mb-2">Tokenomics</h1>
        <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl">
          How the tokens actually work. What gets burned, what gets diluted, what gets ignored.
        </p>
      </div>
    </div>
  </div>

  <div class="grid gap-6">
    {entries.map((entry) => (
      <Card href={`/tokenomics/${entry.id}/`}>
        <div class="text-sm text-[var(--color-text-tertiary)] mb-2">
          {entry.data.publishDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
        </div>
        <h2 class="text-xl font-semibold mb-2">{entry.data.title}</h2>
        <p class="text-[var(--color-text-secondary)]">{entry.data.description}</p>
      </Card>
    ))}
  </div>

  {entries.length === 0 && (
    <p class="text-[var(--color-text-tertiary)] py-12 text-center">Coming soon.</p>
  )}
</ContentLayout>
