---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <div class="flex flex-col items-center justify-center py-24 px-4 text-center">
    <h1 class="text-6xl font-bold text-[var(--color-accent)] mb-4">404</h1>
    <p class="text-xl text-[var(--color-text-secondary)] mb-8">
      This page doesn't exist. Maybe it was decentralised too well.
    </p>
    <a
      href="/"
      class="inline-flex items-center px-6 py-3 rounded-lg bg-[var(--color-accent)] text-white font-medium hover:bg-[var(--color-accent-hover)] transition-colors no-underline"
    >
      Go home
    </a>
  </div>
</BaseLayout>
