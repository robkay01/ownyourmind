---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import ParticleNetwork from '../components/ParticleNetwork.astro';
import MeshGradient from '../components/MeshGradient.astro';
import ProjectLogo from '../components/ProjectLogo.astro';
import { getCollection } from 'astro:content';

const journalEntries = (await getCollection('journal'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const latestPost = journalEntries[0];

// Featured projects: top 4 by freedom score
const allProjects = (await getCollection('projects'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.freedomScore - a.data.freedomScore);
const featuredProjects = allProjects.slice(0, 4);

const scoreColor = (s: number) => s >= 7 ? '#10B981' : s >= 4 ? '#F59E0B' : '#EF4444';

const sections = [
  {
    title: 'Why DeAI',
    description: 'The thesis for decentralised AI — sovereignty, freedom, and why it matters.',
    href: '/why-deai/',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
  },
  {
    title: 'Projects',
    description: 'Honest reviews of decentralised AI projects. Freedom scores, tokenomics, and how to participate.',
    href: '/projects/',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>`,
  },
  {
    title: 'Tokenomics',
    description: 'How the tokens actually work. Economic analysis from a practitioner perspective.',
    href: '/tokenomics/',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v12M8 10h8M8 14h8"/></svg>`,
  },
  {
    title: 'Build',
    description: 'Hands-on tutorials and guides. Run your own nodes, set up hardware, deploy models.',
    href: '/build/',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    title: 'Journal',
    description: 'Weekly dispatches from the frontier of decentralised AI.',
    href: '/journal/',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  },
  {
    title: 'Resources',
    description: 'Reference material, directories, and tools for the decentralised AI ecosystem.',
    href: '/resources/',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
  },
];
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="relative overflow-hidden py-20 sm:py-28">
    <img src="/images/hero-network.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-20 pointer-events-none" loading="eager" />
    <ParticleNetwork particleCount={20} connectionCount={10} />
    <MeshGradient variant="hero" />
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight mb-6">
          Own Your Mind
        </h1>
        <p class="text-xl sm:text-2xl text-[var(--color-text-secondary)] leading-relaxed mb-8">
          Practitioner-led coverage of decentralised AI.<br />
          <span class="text-[var(--color-accent)]">Freedom AND returns.</span> Sovereignty-first. Hands-on.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/why-deai/"
            class="inline-flex items-center px-6 py-3 rounded-lg bg-[var(--color-accent)] font-medium hover:bg-[var(--color-accent-hover)] transition-colors no-underline"
            style="color: #fff;"
          >
            Start here
          </a>
          <a
            href="/journal/"
            class="inline-flex items-center px-6 py-3 rounded-lg border border-[var(--color-border)] text-[var(--color-text-secondary)] font-medium hover:border-[var(--color-border-hover)] hover:text-[var(--color-text-primary)] transition-colors no-underline"
          >
            Latest journal
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Section Cards -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {sections.map((section, i) => (
          <Card href={section.href} class={`reveal reveal-delay-${(i % 3) + 1} border-t-2 border-t-[var(--color-accent)]/20`}>
            <div class="flex items-center gap-2 mb-2">
              <span class="text-[var(--color-accent)]" set:html={section.icon} />
              <h3 class="text-lg font-semibold">{section.title}</h3>
            </div>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
              {section.description}
            </p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="py-12 border-t border-[var(--color-border)]">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-baseline justify-between mb-6">
          <h2 class="text-2xl font-bold">Top-rated projects</h2>
          <a href="/projects/" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] no-underline transition-colors">
            View all &rarr;
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {featuredProjects.map((project) => (
            <a
              href={`/projects/${project.id}/`}
              class="card-elevated p-4 no-underline block"
            >
              <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-2">
                  <ProjectLogo slug={project.id} title={project.data.title} size={32} class="shrink-0" />
                  <span class="font-semibold text-[var(--color-text-primary)]">{project.data.title}</span>
                </div>
                <span class="text-xs font-mono text-[var(--color-accent)]">{project.data.token}</span>
              </div>
              <div class="flex items-center gap-2 mb-2">
                <div class="flex-1 h-1.5 rounded-full bg-[var(--color-bg-primary)]">
                  <div
                    class="h-full rounded-full"
                    style={`width: ${project.data.freedomScore * 10}%; background-color: ${scoreColor(project.data.freedomScore)};`}
                  />
                </div>
                <span class="text-sm font-bold font-[var(--font-heading)]" style={`color: ${scoreColor(project.data.freedomScore)};`}>
                  {project.data.freedomScore}
                </span>
              </div>
              <span class="badge bg-[var(--color-bg-tertiary)] text-[var(--color-text-secondary)] border border-[var(--color-border)] text-xs">
                {project.data.category}
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Latest Journal Entry -->
  {latestPost && (
    <section class="py-12 border-t border-[var(--color-border)]">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-baseline justify-between mb-6">
          <h2 class="text-2xl font-bold">Latest from the journal</h2>
          <a href="/journal/" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] no-underline transition-colors">
            View all &rarr;
          </a>
        </div>
        <Card href={`/journal/${latestPost.id}/`}>
          <div class="text-sm text-[var(--color-text-tertiary)] mb-2">
            {latestPost.data.publishDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
          </div>
          <h3 class="text-xl font-semibold mb-2">{latestPost.data.title}</h3>
          <p class="text-[var(--color-text-secondary)]">{latestPost.data.description}</p>
        </Card>
      </div>
    </section>
  )}

  <!-- Newsletter Signup -->
  <section class="py-16 border-t border-[var(--color-border)] relative overflow-hidden">
    <MeshGradient variant="subtle" />
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-xl mx-auto text-center">
        <h2 class="text-2xl font-bold mb-4">Stay sovereign</h2>
        <p class="text-[var(--color-text-secondary)] mb-8">
          Weekly dispatches on decentralised AI. No spam, no shilling. Unsubscribe anytime.
        </p>
        <form
          action="https://buttondown.com/api/emails/embed-subscribe/ownyourmind"
          method="post"
          target="popupwindow"
          class="flex flex-col sm:flex-row gap-3"
        >
          <input
            type="email"
            name="email"
            placeholder="you@example.com"
            required
            class="flex-1 px-4 py-3 rounded-lg bg-[var(--color-bg-tertiary)] border border-[var(--color-border)] text-[var(--color-text-primary)] placeholder:text-[var(--color-text-tertiary)] focus:border-[var(--color-accent)] focus:outline-none transition-colors"
          />
          <button
            type="submit"
            class="px-6 py-3 rounded-lg bg-[var(--color-accent)] text-white font-medium hover:bg-[var(--color-accent-hover)] transition-colors"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
