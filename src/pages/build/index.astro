---
import ContentLayout from '../../layouts/ContentLayout.astro';
import Card from '../../components/Card.astro';
import Badge from '../../components/Badge.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('build'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<ContentLayout
  title="Build"
  description="Hands-on tutorials and guides for decentralised AI."
  breadcrumbs={[{ label: 'Build' }]}
>
  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold mb-4">Build</h1>
    <p class="text-lg text-[var(--color-text-secondary)]">
      Hands-on tutorials and guides. Run your own nodes, set up hardware, deploy models.
    </p>
  </div>

  <div class="grid gap-6">
    {entries.map((entry) => (
      <Card href={`/build/${entry.id}/`}>
        <div class="flex items-center gap-3 mb-3">
          <Badge variant="difficulty" value={entry.data.difficulty} />
          <Badge variant="category" value={entry.data.category} />
        </div>
        <h2 class="text-xl font-semibold mb-2">{entry.data.title}</h2>
        <p class="text-[var(--color-text-secondary)]">{entry.data.description}</p>
      </Card>
    ))}
  </div>

  {entries.length === 0 && (
    <p class="text-[var(--color-text-tertiary)] py-12 text-center">Coming soon.</p>
  )}
</ContentLayout>
