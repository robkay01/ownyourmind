---
import { getCollection, render } from 'astro:content';
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import { getProjectResearch } from '../../data/project-research';
import type { ProjectResearchRecord } from '../../data/project-research';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const research: ProjectResearchRecord | null = getProjectResearch(entry.id);
---

<ProjectLayout
  title={entry.data.title}
  description={entry.data.description}
  category={entry.data.category}
  token={entry.data.token}
  status={entry.data.status}
  freedomScore={entry.data.freedomScore}
  publishDate={entry.data.publishDate}
  updatedDate={entry.data.updatedDate}
  coingeckoId={entry.data.coingeckoId}
  verdict={entry.data.verdict}
  oymHolds={entry.data.oymHolds}
  research={research}
>
  <Content />
</ProjectLayout>
