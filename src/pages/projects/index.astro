---
import ContentLayout from '../../layouts/ContentLayout.astro';
import Card from '../../components/Card.astro';
import Badge from '../../components/Badge.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('projects'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<ContentLayout
  title="Projects"
  description="Honest reviews of decentralised AI projects with freedom scores."
  breadcrumbs={[{ label: 'Projects' }]}
>
  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold mb-4">Projects</h1>
    <p class="text-lg text-[var(--color-text-secondary)]">
      Honest reviews of decentralised AI projects. Freedom scores, tokenomics, and how to participate.
    </p>
  </div>

  <div class="grid gap-6">
    {entries.map((entry) => {
      const scoreColor = entry.data.freedomScore >= 7 ? '#10B981' : entry.data.freedomScore >= 4 ? '#F59E0B' : '#EF4444';
      return (
        <Card href={`/projects/${entry.id}/`}>
          <div class="flex items-center gap-3 mb-3">
            <Badge variant="status" value={entry.data.status} />
            <Badge variant="category" value={entry.data.category} />
            <span class="text-sm font-mono text-[var(--color-accent)]">{entry.data.token}</span>
            <span class="ml-auto text-sm font-bold" style={`color: ${scoreColor};`}>
              {entry.data.freedomScore}/10
            </span>
          </div>
          <h2 class="text-xl font-semibold mb-2">{entry.data.title}</h2>
          <p class="text-[var(--color-text-secondary)]">{entry.data.description}</p>
        </Card>
      );
    })}
  </div>

  {entries.length === 0 && (
    <p class="text-[var(--color-text-tertiary)] py-12 text-center">Coming soon.</p>
  )}
</ContentLayout>
